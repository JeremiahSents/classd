{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@workspace/ui/components/button": [
        "../../packages/ui/src/components/button.native"
      ],
      "@workspace/ui/tokens": [
        "../../packages/ui/src/tokens/index"
      ],
      "react-native": [
        "./node_modules/react-native"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
