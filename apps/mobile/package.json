{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --android --clear",
    "ios": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --ios --clear",
    "web": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --web --clear",
    "eas:login": "eas login",
    "eas:preview": "eas build --platform android --profile preview",
    "eas:android": "eas build --platform android --profile production",
    "eas:ios": "eas build --platform ios --profile production",
    "eas:update": "eas update --branch production",
    "eas:submit:android": "eas submit --platform android --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.35",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.7",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "^0.1.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.14.0",
    "lucide-react-native": "^0.460.0",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
