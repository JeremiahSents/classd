# Firebase client config for the mobile app.
# Copy to `.env` and fill in from the Firebase console:
#   Project settings → General → Your apps → SDK setup and configuration
#
# EXPO_PUBLIC_ prefix is REQUIRED — only those vars are exposed to the app
# bundle at build time. Restart `expo start --clear` after changing these.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=classd-f6db8.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=classd-f6db8
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=classd-f6db8.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=904584111105
EXPO_PUBLIC_FIREBASE_APP_ID=1:904584111105:web:455266fd411e6b54adcc00

# Google OAuth client IDs for frontend Google sign-in.
# Create these in Google Cloud/Firebase, then wire them in `lib/google-auth.ts`.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Set to "firebase" to use the live backend, "mock" to use seed data.
EXPO_PUBLIC_API_BACKEND=mock
