{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  // Don't type-check or index library source (e.g. node_modules/expo-modules-core/src).
  // These ship raw TS that errors in isolation but never affects our build.
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.validate.enable": true,
  "files.watcherExclude": {
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/node_modules": true
  },
  "files.exclude": {
    "**/node_modules": true
  }
}
